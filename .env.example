# [Database Configuration]
# Oracle 21c XE 기준 PDB 서비스 이름인 XEPDB1을 사용합니다.
SPRING_DATASOURCE_URL=jdbc:oracle:thin:@db:1521/XEPDB1
SPRING_DATASOURCE_USERNAME=EASYEARTH
SPRING_DATASOURCE_PASSWORD=EASYEARTH

# [Security]
JWT_SECRET=your_jwt_secret_key_here

# [AI & External APIs]
GEMINI_API_KEY=your_gemini_api_key

# [지도 / 경로 API]
# ODSAY 대중교통 경로 API
ODSAY_API_KEY=your_odsay_key
# OpenRouteService (자동차/도보 경로)
ORS_API_KEY=your_ors_key
# 서울맵 테마 키
SEOULMAP_THEME_KEY=your_seoulmap_key

# [Weather API (기상청)]
KMA_SERVICE_KEY=your_kma_public_data_key
KMA_AUTH_KEY=your_kma_apihub_auth_key

# [Social Login & Search]
# Kakao
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
# Naver (뉴스 검색용)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret