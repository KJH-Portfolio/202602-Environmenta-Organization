<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<mapper namespace="com.kh.spring.ecotree.model.dao.EcoTreeMapper">

    <resultMap id="ecoTreeResultMap" type="com.kh.spring.ecotree.model.vo.EcoTreeVO">
        <id property="memberId" column="MEMBER_ID"/>
        <result property="treeLevel" column="TREE_LEVEL"/>
        <result property="syncedExp" column="SYNCED_EXP"/>
        <result property="lastGrowthDate" column="LAST_GROWTH_DATE"/>
        <result property="totalEarnedPoint" column="TOTAL_EARNED_POINT"/>
    </resultMap>

    <!-- 회원의 나무 정보와 월렛의 누적 포인트를 함께 조회 -->
    <select id="selectTreeByMemberId" parameterType="int" resultMap="ecoTreeResultMap">
        SELECT 
            E.MEMBER_ID,
            E.TREE_LEVEL,
            E.SYNCED_EXP,
            E.LAST_GROWTH_DATE,
            W.TOTAL_EARNED_POINT
        FROM ECO_TREE E
        JOIN POINT_WALLET W ON E.MEMBER_ID = W.MEMBER_ID
        WHERE E.MEMBER_ID = #{memberId}
    </select>

    <!-- 나무 정보 초기 생성 -->
    <insert id="insertTree" parameterType="int">
        INSERT INTO ECO_TREE (MEMBER_ID, TREE_LEVEL, SYNCED_EXP, LAST_GROWTH_DATE)
        VALUES (#{memberId}, 1, 0, SYSDATE)
    </insert>

    <!-- 나무 성장 업데이트 -->
    <update id="updateTreeGrowth" parameterType="com.kh.spring.ecotree.model.vo.EcoTreeVO">
        UPDATE ECO_TREE
        SET TREE_LEVEL = #{treeLevel},
            SYNCED_EXP = #{syncedExp},
            LAST_GROWTH_DATE = SYSDATE
        WHERE MEMBER_ID = #{memberId}
    </update>

</mapper>
